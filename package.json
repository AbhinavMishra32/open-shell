{
  "name": "opaline",
  "version": "0.3.0",
  "private": true,
  "packageManager": "npm@11.6.1",
  "description": "A research-driven Electron component system for modern agentic desktop apps.",
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "npm run build -w @opaline/ui && turbo run dev --filter=@opaline/electron-example",
    "docs:build": "npm run build -w @opaline/docs",
    "docs:dev": "npm run dev -w @opaline/docs",
    "docs:start": "npm run start -w @opaline/docs",
    "install:ui": "node scripts/install-opaline-ui.mjs",
    "start": "npm run build -w @opaline/ui && npm run start -w @opaline/electron-example",
    "start:example": "npm run build -w @opaline/ui && npm run start -w @opaline/electron-example",
    "typecheck": "turbo run typecheck",
    "research:refresh": "npm run refresh:components --prefix research/opaline-internals",
    "research:start": "npm run start --prefix research/opaline-internals"
  },
  "devDependencies": {
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "turbo": "^2.9.16",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@radix-ui/react-context-menu": "^2.2.16",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0"
  }
}
