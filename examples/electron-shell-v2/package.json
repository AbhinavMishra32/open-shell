{
  "name": "@opaline/electron-example-v2",
  "productName": "Opaline Example v2",
  "version": "0.3.0",
  "private": true,
  "description": "Example Electron app consuming shadcn-based @opaline/ui/components.",
  "main": "src/main/main.cjs",
  "scripts": {
    "start": "npm run build && electron .",
    "predev": "npm run build -w @opaline/ui",
    "dev": "vite --host 127.0.0.1",
    "prebuild": "npm run build -w @opaline/ui",
    "build": "vite build",
    "pretypecheck": "npm run build -w @opaline/ui",
    "typecheck": "tsc --noEmit --pretty false"
  },
  "dependencies": {
    "@opaline/ui": "*",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "42.1.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.2.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}
