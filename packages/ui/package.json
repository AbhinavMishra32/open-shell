{
  "name": "@opaline/ui",
  "version": "0.3.0",
  "description": "High-fidelity React primitives, shell layouts, and Electron UX systems for agentic desktop apps.",
  "license": "MIT",
  "homepage": "https://github.com/AbhinavMishra32/opaline#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AbhinavMishra32/opaline.git",
    "directory": "packages/ui"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "imports": {
    "#lib/*": "./src/lib/*.ts",
    "#components/*": "./src/components/*.tsx",
    "#hooks/*": "./src/hooks/*.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js",
      "default": "./dist/components/index.js"
    },
    "./v2": {
      "types": "./dist/opaline-v2/index.d.ts",
      "import": "./dist/opaline-v2/index.js",
      "default": "./dist/opaline-v2/index.js"
    },
    "./v2/styles.css": "./dist/opaline-v2/styles.css",
    "./styles.css": "./dist/styles.css",
    "./theme.css": "./src/theme.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json --pretty false && node scripts/copy-css.mjs",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit --pretty false"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.542.0",
    "radix-ui": "^1.4.3",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}
