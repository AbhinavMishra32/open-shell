{
  "name": "@opaline/docs",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Documentation and interactive component playground for Opaline UI.",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3011",
    "build": "next build",
    "generate": "fumadocs-mdx",
    "start": "next start --hostname 127.0.0.1 --port 3011",
    "typecheck": "npm run generate && tsc --noEmit --pretty false"
  },
  "dependencies": {
    "@opaline/ui": "*",
    "@tailwindcss/postcss": "^4.3.0",
    "fumadocs-core": "^16.9.3",
    "fumadocs-mdx": "^15.0.11",
    "fumadocs-ui": "^16.9.3",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@types/mdx": "^2.0.13"
  }
}
